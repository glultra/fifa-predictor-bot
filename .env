# ============================================================
#  World Cup 2026 Poll Bot — configuration
#  Copy this file to ".env" and fill in the two REQUIRED values.
# ============================================================

# --- REQUIRED ---------------------------------------------------------------

# Your bot token from the Discord Developer Portal (Bot tab -> Reset Token).
DISCORD_TOKEN=test

# The numeric ID of the channel where polls should be posted.
# Enable Developer Mode in Discord (Settings -> Advanced), then right-click the
# channel -> "Copy Channel ID".
CHANNEL_ID=1150110622999117824
LEAD_HOURS: "60"
# --- OPTIONAL (sensible defaults shown) -------------------------------------

# How many hours BEFORE kick-off to post the poll.
LEAD_HOURS=12

# If true, the poll closes exactly at kick-off. If false, it stays open
# for POLL_HOURS instead.
CLOSE_AT_KICKOFF=true
POLL_HOURS=12

# Wait until knockout-round teams are actually decided before posting those
# polls (recommended). If false, the bot would post "2A vs 2B" style polls.
SKIP_PLACEHOLDERS=true

# Local fixtures snapshot. The bot reads this file and refreshes it from
# openfootball automatically (see REFRESH_HOURS).
FIXTURES_FILE=fixtures_2026.json

# Re-download the fixtures every N hours so results/knockout teams stay current.
# Set to 0 to disable network refresh and only use the local file.
REFRESH_HOURS=6

# How often (seconds) the bot checks the schedule.
CHECK_SECONDS=60

# File used to remember which matches were already posted (so a restart
# doesn't double-post). Leave as-is unless you have a reason to change it.
STATE_FILE=posted.json
